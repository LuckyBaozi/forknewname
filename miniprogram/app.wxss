/* ============================================================
   全局样式 — 国风主题
   ============================================================ */

page {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'STSong', 'SimSun', serif;
  font-size: 28rpx;
  color: #3c3c3c;
  background: #f5f0e8;
  line-height: 1.7;
}

/* 宣纸纹理背景 */
page::before {
  content: '';
  position: fixed;
  inset: 0;
  z-index: -1;
  opacity: 0.06;
  background:
    radial-gradient(ellipse at 20% 50%, #8b5e3c 0%, transparent 50%),
    radial-gradient(ellipse at 80% 20%, #b3453a 0%, transparent 50%),
    radial-gradient(ellipse at 50% 80%, #c9a96e 0%, transparent 50%);
}

/* Layout */
.container {
  padding: 28rpx;
  min-height: 100vh;
}

/* Text */
.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #2c2416;
  letter-spacing: 4rpx;
}
.subtitle {
  font-size: 28rpx;
  color: #8b7355;
}
.disclaimer {
  font-size: 22rpx;
  color: #b8a88a;
  text-align: center;
  margin-top: 40rpx;
}

/* Buttons */
.btn-primary {
  display: block;
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #b3453a, #8b2500);
  color: #f5e6c8;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  border-radius: 8rpx;
  border: 1rpx solid #c9a96e;
  box-shadow: 0 4rpx 16rpx rgba(139, 37, 0, 0.25);
  letter-spacing: 2rpx;
}
.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}
.btn-primary[disabled] {
  background: #d5cfc6;
  border-color: #c5bfb5;
  color: #b5afa5;
  box-shadow: none;
}

.btn-outline {
  display: inline-block;
  padding: 16rpx 28rpx;
  background: #faf6f0;
  color: #6b5a4a;
  font-size: 28rpx;
  border: 1rpx solid #c9a96e;
  border-radius: 6rpx;
  text-align: center;
}

.btn-small {
  display: inline-block;
  padding: 12rpx 24rpx;
  background: #f5f0e8;
  color: #8b7355;
  font-size: 24rpx;
  border: 1rpx solid #d5cfc6;
  border-radius: 4rpx;
}

/* Form */
.form-group {
  margin-bottom: 28rpx;
}
.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #4a3728;
  margin-bottom: 10rpx;
}
.form-label .required {
  color: #b3453a;
  margin-left: 4rpx;
}
.form-input {
  width: 100%;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  background: #faf6f0;
  border: 1rpx solid #d5cfc6;
  border-radius: 6rpx;
  color: #3c3c3c;
  box-sizing: border-box;
}
.form-input:focus {
  border-color: #c9a96e;
  background: #fffdf8;
}

/* Cards */
.card {
  background: #faf6f0;
  border-radius: 8rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #e5dccf;
  box-shadow: 0 2rpx 8rpx rgba(139, 94, 60, 0.06);
}

/* Tags */
.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  background: #f5f0e8;
  color: #8b7355;
  font-size: 24rpx;
  border-radius: 4rpx;
  border: 1rpx solid #d5cfc6;
  margin: 4rpx 8rpx 4rpx 0;
}
.tag.selected {
  background: #b3453a;
  color: #f5e6c8;
  border-color: #8b2500;
}

/* Toast */
.toast-msg {
  padding: 16rpx 32rpx;
  background: rgba(44, 36, 22, 0.85);
  color: #f5e6c8;
  font-size: 26rpx;
  border-radius: 6rpx;
  text-align: center;
}

/* Empty state */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #b8a88a;
}
.empty-state .icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

/* Decorative 国风 elements */
.guofeng-border {
  border: 1rpx solid #c9a96e;
  position: relative;
}
.guofeng-border::after {
  content: '';
  position: absolute;
  inset: 2rpx;
  border: 1rpx solid rgba(201, 169, 110, 0.3);
  pointer-events: none;
}
