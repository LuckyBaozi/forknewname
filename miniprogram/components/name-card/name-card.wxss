.name-card {
  background: #faf6f0;
  border-radius: 8rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #e5dccf;
  box-shadow: 0 2rpx 10rpx rgba(139, 94, 60, 0.05);
  position: relative;
}

/* 卡片左上角装饰 */
.name-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 8rpx; height: 8rpx;
  border-top: 2rpx solid #c9a96e;
  border-left: 2rpx solid #c9a96e;
  border-radius: 2rpx 0 0 0;
}

/* 卡片右下角装饰 */
.name-card::after {
  content: '';
  position: absolute;
  bottom: 0; right: 0;
  width: 8rpx; height: 8rpx;
  border-bottom: 2rpx solid #c9a96e;
  border-right: 2rpx solid #c9a96e;
  border-radius: 0 0 2rpx 0;
}

.name-header {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.full-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #b3453a;
  letter-spacing: 4rpx;
  font-family: 'STKaiti', 'KaiTi', 'SimSun', serif;
}

.pronunciation {
  font-size: 26rpx;
  color: #b8a88a;
  font-style: italic;
}

.tag-row {
  margin-bottom: 16rpx;
}

.tag {
  display: inline-block;
  padding: 6rpx 14rpx;
  background: linear-gradient(135deg, rgba(201, 169, 110, 0.15), rgba(179, 69, 58, 0.05));
  color: #8b5e3c;
  font-size: 22rpx;
  border-radius: 4rpx;
  margin-right: 6rpx;
  margin-bottom: 4rpx;
  border: 1rpx solid rgba(201, 169, 110, 0.3);
}

.section {
  margin-bottom: 14rpx;
}

.section-label {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #8b7355;
  margin-bottom: 4rpx;
}

.section-text {
  font-size: 26rpx;
  color: #5a4a3a;
  line-height: 1.7;
}

.action-bar {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #e5dccf;
}

.action-btn {
  padding: 10rpx 20rpx;
  background: #f5f0e8;
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #8b7355;
  border: 1rpx solid #d5cfc6;
}

.action-btn.favorited {
  background: linear-gradient(135deg, rgba(201, 169, 110, 0.2), rgba(179, 69, 58, 0.1));
  color: #b3453a;
  border-color: rgba(179, 69, 58, 0.3);
}

.action-btn:active {
  opacity: 0.7;
}
