.name-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.name-header {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.full-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #c0392b;
}

.pronunciation {
  font-size: 26rpx;
  color: #999;
  font-style: italic;
}

.tag-row {
  margin-bottom: 20rpx;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: #fef3e2;
  color: #e67e22;
  font-size: 22rpx;
  border-radius: 8rpx;
  margin-right: 8rpx;
  margin-bottom: 4rpx;
}

.section {
  margin-bottom: 16rpx;
}

.section-label {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #888;
  margin-bottom: 6rpx;
}

.section-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.7;
}

.action-bar {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  padding: 10rpx 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666;
}

.action-btn.favorited {
  background: #fef3e2;
  color: #e67e22;
}

.action-btn:active {
  opacity: 0.7;
}
