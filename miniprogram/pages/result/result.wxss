.result-header {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.result-header .btn-outline {
  flex: 1;
  text-align: center;
}

.cache-indicator {
  text-align: center;
  padding: 16rpx;
  background: #e8f0fe;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #4a90d9;
  margin-bottom: 24rpx;
}

.loading {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
}

.result-count {
  text-align: center;
  margin-bottom: 24rpx;
  font-size: 28rpx;
  color: #666;
}
.result-count .highlight {
  color: #c0392b;
  font-weight: 700;
  font-size: 36rpx;
}

.share-section {
  margin-top: 32rpx;
  margin-bottom: 32rpx;
}
.share-btn {
  background: linear-gradient(135deg, #27ae60, #2ecc71);
  box-shadow: 0 4rpx 12rpx rgba(46, 204, 113, 0.3);
}
