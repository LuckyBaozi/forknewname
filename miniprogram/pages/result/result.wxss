.result-header {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}
.result-header .btn-outline {
  flex: 1;
  text-align: center;
}

.cache-indicator {
  text-align: center;
  padding: 14rpx;
  background: linear-gradient(135deg, rgba(201, 169, 110, 0.15), rgba(179, 69, 58, 0.05));
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #8b7355;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(201, 169, 110, 0.2);
}

.loading {
  text-align: center;
  padding: 80rpx 0;
  color: #b8a88a;
}

.result-count {
  text-align: center;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  color: #6b5a4a;
}
.result-count .highlight {
  color: #b3453a;
  font-weight: 700;
  font-size: 36rpx;
}

.share-section {
  margin-top: 28rpx;
  margin-bottom: 28rpx;
}
.share-btn {
  background: linear-gradient(135deg, #c9a96e, #8b7355) !important;
  box-shadow: 0 4rpx 16rpx rgba(139, 94, 60, 0.25) !important;
  border-color: #8b7355 !important;
}
