.home {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 100rpx;
  min-height: 100vh;
}

/* 顶部装饰边框 */
.home::before {
  content: '';
  position: absolute;
  top: 0; left: 40rpx; right: 40rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #c9a96e, transparent);
}

/* Hero */
.hero {
  text-align: center;
  margin-bottom: 60rpx;
}
.hero-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(139, 37, 0, 0.15));
}
.hero-title {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: #2c2416;
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
  font-family: 'STKaiti', 'KaiTi', 'SimSun', serif;
}
.hero-subtitle {
  display: block;
  font-size: 26rpx;
  color: #8b7355;
  letter-spacing: 2rpx;
}

/* 分隔装饰线 */
.hero::after {
  content: ' ◆ ';
  display: block;
  font-size: 16rpx;
  color: #c9a96e;
  margin-top: 24rpx;
  letter-spacing: 8rpx;
}

/* Features flow */
.features {
  display: flex;
  align-items: center;
  margin-bottom: 60rpx;
  gap: 8rpx;
  padding: 28rpx 20rpx;
  background: rgba(250, 246, 240, 0.7);
  border-radius: 8rpx;
  border: 1rpx solid rgba(201, 169, 110, 0.3);
}
.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.feature-icon {
  font-size: 40rpx;
}
.feature-text {
  font-size: 22rpx;
  color: #6b5a4a;
}
.feature-arrow {
  font-size: 28rpx;
  color: #c9a96e;
}

/* Start button */
.start-btn {
  width: 70%;
  max-width: 480rpx;
  margin-bottom: 36rpx;
  font-size: 36rpx;
  padding: 32rpx;
  letter-spacing: 6rpx;
  border-radius: 8rpx;
}

/* Favorites entry */
.fav-entry {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 36rpx;
  background: #faf6f0;
  border-radius: 6rpx;
  font-size: 28rpx;
  color: #c9a96e;
  margin-bottom: 36rpx;
  border: 1rpx solid rgba(201, 169, 110, 0.4);
}
.fav-count {
  color: #8b7355;
  font-size: 24rpx;
}
