.home {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

/* Hero */
.hero {
  text-align: center;
  margin-bottom: 80rpx;
}
.hero-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}
.hero-title {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}
.hero-subtitle {
  display: block;
  font-size: 28rpx;
  color: #999;
}

/* Features flow */
.features {
  display: flex;
  align-items: center;
  margin-bottom: 80rpx;
  gap: 12rpx;
}
.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.feature-icon {
  font-size: 48rpx;
}
.feature-text {
  font-size: 22rpx;
  color: #666;
}
.feature-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* Start button */
.start-btn {
  width: 80%;
  max-width: 500rpx;
  margin-bottom: 40rpx;
  font-size: 36rpx;
  padding: 32rpx;
}

/* Favorites entry */
.fav-entry {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 40rpx;
  background: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #f39c12;
  margin-bottom: 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.fav-count {
  color: #999;
  font-size: 24rpx;
}
