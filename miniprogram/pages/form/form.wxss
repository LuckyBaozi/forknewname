/* 姓氏输入框 — 防止 maxlength=2 导致窄缩和高度不足 */
.surname-input {
  width: 100% !important;
  min-width: 100% !important;
  max-width: 100% !important;
  height: 88rpx !important;
  min-height: 88rpx !important;
  line-height: 48rpx;
  padding: 20rpx 24rpx !important;
  box-sizing: border-box;
}

.form-intro {
  background: linear-gradient(135deg, rgba(201, 169, 110, 0.12), rgba(179, 69, 58, 0.08));
  padding: 20rpx 24rpx;
  border-radius: 6rpx;
  margin-bottom: 28rpx;
  border: 1rpx solid rgba(201, 169, 110, 0.25);
}
.form-intro-text {
  font-size: 26rpx;
  color: #6b5a4a;
}

/* Radio group */
.radio-group {
  display: flex;
  gap: 16rpx;
}
.radio-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background: #faf6f0;
  border: 1rpx solid #d5cfc6;
  border-radius: 6rpx;
  font-size: 28rpx;
  color: #8b7355;
}
.radio-item.active {
  border-color: #b3453a;
  background: linear-gradient(135deg, rgba(179, 69, 58, 0.1), rgba(201, 169, 110, 0.15));
  color: #b3453a;
  font-weight: 600;
}

/* Tag group (for styles) */
.tag-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.tag {
  display: inline-block;
  padding: 16rpx 32rpx;
  background: #faf6f0;
  border: 1rpx solid #d5cfc6;
  border-radius: 6rpx;
  font-size: 28rpx;
  color: #8b7355;
}
.tag.selected {
  border-color: #b3453a;
  background: linear-gradient(135deg, rgba(179, 69, 58, 0.15), rgba(201, 169, 110, 0.1));
  color: #b3453a;
  font-weight: 600;
}

/* Picker */
.picker-view {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 20rpx 24rpx;
  background: #faf6f0;
  border: 1rpx solid #d5cfc6;
  border-radius: 6rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.placeholder {
  color: #b8a88a;
}
.picker-arrow {
  font-size: 24rpx;
  color: #b8a88a;
}

/* Error */
.input-error {
  border-color: #b3453a !important;
  background: #fdf5f3 !important;
}
.error-text {
  display: block;
  font-size: 22rpx;
  color: #b3453a;
  margin-top: 8rpx;
  padding-left: 4rpx;
}

/* Optional label */
.optional {
  font-size: 22rpx;
  color: #b8a88a;
  font-weight: 400;
  margin-left: 8rpx;
}

/* Actions */
.form-actions {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.btn-reset {
  display: block;
  width: 100%;
  padding: 22rpx;
  background: #f5f0e8;
  color: #8b7355;
  font-size: 28rpx;
  text-align: center;
  border-radius: 6rpx;
  border: 1rpx solid #d5cfc6;
}
