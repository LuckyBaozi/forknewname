.ad-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
  min-height: 100vh;
}

.ad-status {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.spinner {
  width: 56rpx;
  height: 56rpx;
  border: 3rpx solid #e5dccf;
  border-top-color: #b3453a;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 28rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.status-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #3c3c3c;
  margin-bottom: 10rpx;
}
.status-text.error {
  color: #b3453a;
}

.status-hint {
  font-size: 26rpx;
  color: #8b7355;
  margin-bottom: 36rpx;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

/* Ad hint */
.ad-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}
.ad-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(139, 37, 0, 0.1));
}
.ad-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2c2416;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}
.ad-subtitle {
  font-size: 26rpx;
  color: #8b7355;
  margin-bottom: 6rpx;
}
.ad-warning {
  font-size: 24rpx;
  color: #b3453a;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, rgba(179, 69, 58, 0.08), rgba(201, 169, 110, 0.05));
  border-radius: 4rpx;
  border: 1rpx solid rgba(179, 69, 58, 0.15);
}

.retry-btn {
  width: 60%;
  max-width: 400rpx;
}

.back-link {
  margin-top: 64rpx;
  font-size: 26rpx;
  color: #b8a88a;
}
