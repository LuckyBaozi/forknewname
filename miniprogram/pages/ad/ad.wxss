.ad-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.ad-status {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #4a90d9;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 32rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.status-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}
.status-text.error {
  color: #e74c3c;
}

.status-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

/* Ad hint */
.ad-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}
.ad-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}
.ad-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}
.ad-subtitle {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 8rpx;
}
.ad-warning {
  font-size: 24rpx;
  color: #e74c3c;
  padding: 8rpx 16rpx;
  background: #fff5f5;
  border-radius: 8rpx;
}

.retry-btn {
  width: 60%;
  max-width: 400rpx;
}

.back-link {
  margin-top: 80rpx;
  font-size: 26rpx;
  color: #999;
}
